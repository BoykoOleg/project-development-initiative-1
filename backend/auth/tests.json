{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Init admin",
      "method": "POST",
      "path": "/?action=init-admin",
      "body": {"email": "BoykoOleg2011@mail.ru", "password": "AutoServ#9X2k", "name": "Администратор"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "BoykoOleg2011@mail.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login success",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "BoykoOleg2011@mail.ru", "password": "AutoServ#9X2k"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "List users without token",
      "method": "GET",
      "path": "/?action=list-users",
      "expectedStatus": 401
    }
  ]
}