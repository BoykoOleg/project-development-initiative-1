{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get calls list from DB",
      "method": "GET",
      "path": "/?action=list_db",
      "expectedStatus": 200,
      "expectedBody": {"source": "db"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Webhook POST from Mobilon",
      "method": "POST",
      "path": "/",
      "body": {"from": "89659080388", "to": "89135198558", "baseid": "test123.000001", "state": "HANGUP", "direction": "incoming", "uuid": "test-uuid-0001", "time": 1700000000, "subid": "test123.000002", "userkey": "testkey", "duration": "0"},
      "expectedStatus": 200,
      "expectedBody": "ok",
      "bodyMatcher": "exact"
    },
    {
      "name": "Ping Mobilon API",
      "method": "GET",
      "path": "/?action=ping",
      "expectedStatus": 200,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Raw request without url",
      "method": "POST",
      "path": "/?action=raw_request",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Transcribe without call_id",
      "method": "GET",
      "path": "/?action=transcribe",
      "expectedStatus": 400,
      "expectedBody": {"error": "call_id is required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Transcribe unknown call",
      "method": "GET",
      "path": "/?action=transcribe&call_id=nonexistent-000",
      "expectedStatus": 404,
      "expectedBody": {"error": "call not found"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Calls by phone without phone",
      "method": "GET",
      "path": "/?action=calls_by_phone&phone=",
      "expectedStatus": 400,
      "expectedBody": {"error": "phone is required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Calls by phone",
      "method": "GET",
      "path": "/?action=calls_by_phone&phone=89000000000",
      "expectedStatus": 200,
      "expectedBody": {"calls": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Active call polling",
      "method": "GET",
      "path": "/?action=active",
      "expectedStatus": 200,
      "expectedBody": {"active": false},
      "bodyMatcher": "partial"
    }
  ]
}